#!/usr/bin/env bash
# Pre-commit hook for treefmt-full-flake
# Fast check: only validates formatting, doesn't auto-format

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit formatting check...${NC}"

if ! command -v nix &> /dev/null; then
    echo -e "${RED}Error: nix is not installed${NC}"
    exit 1
fi

if [ ! -f "flake.nix" ]; then
    echo -e "${RED}Error: Not in a flake project${NC}"
    exit 1
fi

# Quick check only - fail if formatting needed
# Use --no-build to avoid evaluation overhead
if ! nix fmt -- --check --no-cache 2>/dev/null; then
    echo -e "${RED}✗ Formatting check failed${NC}"
    echo "Run 'nix fmt' to fix formatting, then commit again"
    exit 1
fi

echo -e "${GREEN}✓ Formatting check passed${NC}"
exit 0