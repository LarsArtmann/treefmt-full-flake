#!/usr/bin/env bash
# Pre-commit hook for treefmt-full-flake
# Ensures all staged files are properly formatted before commit

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit formatting check...${NC}"

# Check if nix is available
if ! command -v nix &> /dev/null; then
    echo -e "${RED}Error: nix is not installed or not in PATH${NC}"
    echo "Please install Nix or ensure it's in your PATH"
    exit 1
fi

# Check if we're in a flake project
if [ ! -f "flake.nix" ]; then
    echo -e "${RED}Error: Not in a flake project (no flake.nix found)${NC}"
    exit 1
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}No staged files to format${NC}"
    exit 0
fi

# Run formatter on the entire project
echo -e "${YELLOW}Running nix fmt...${NC}"
if ! nix fmt 2>&1; then
    echo -e "${RED}Formatting failed!${NC}"
    echo "Please fix the formatting issues and try again"
    exit 1
fi

# Check if any files were modified by the formatter
MODIFIED_FILES=$(git diff --name-only)

if [ -n "$MODIFIED_FILES" ]; then
    echo -e "${YELLOW}The following files were reformatted:${NC}"
    echo "$MODIFIED_FILES" | sed 's/^/  /'
    
    # Add the formatted files back to staging
    for file in $MODIFIED_FILES; do
        if grep -q "^$file$" <<< "$STAGED_FILES"; then
            git add "$file"
            echo -e "${GREEN}  ✓ Re-staged: $file${NC}"
        fi
    done
    
    echo -e "${GREEN}Files have been formatted and re-staged${NC}"
    echo -e "${YELLOW}Please review the changes before committing${NC}"
fi

echo -e "${GREEN}✓ Pre-commit formatting check passed${NC}"
exit 0