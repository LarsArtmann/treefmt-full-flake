{
  "name": "treefmt-analytics",
  "version": "1.0.0",
  "description": "Performance Analytics for treefmt - Comprehensive monitoring and insights",
  "keywords": [
    "analytics",
    "code-formatting",
    "dashboard",
    "metrics",
    "monitoring",
    "performance",
    "treefmt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LarsArtmann/treefmt-full-flake"
  },
  "author": "Lars Artmann",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "analytics": "bun run analytics-collector.ts",
    "dashboard": "bun run terminal-dashboard-kit.ts",
    "dashboard:blessed": "bun run terminal-dashboard.ts",
    "dev": "bun run --watch terminal-dashboard-kit.ts",
    "test": "bun test",
    "build": "bun build analytics-collector.ts --outdir=dist --target=bun",
    "format": "./smart-treefmt-analytics.sh",
    "analytics:summary": "bun run analytics-collector.ts summary",
    "analytics:export": "bun run analytics-collector.ts export",
    "analytics:dashboard": "bun run terminal-dashboard-kit.ts"
  },
  "dependencies": {
    "terminal-kit": "^3.1.2"
  },
  "devDependencies": {
    "@types/terminal-kit": "^2.5.7",
    "bun-types": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
